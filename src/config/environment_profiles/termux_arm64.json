{
  "profile_name": "termux_arm64",
  "profile_version": "1.0",
  "description": "Perfil principal para Android ARM64 vía Termux - Target principal de Claw-Litle",
  
  "environment": {
    "type": "termux_android",
    "arch": "arm64-v8a",
    "ram_typical_mb": 4096,
    "ram_min_mb": 2048,
    "storage_paths": [
      "/sdcard/clawlite-data/",
      "/data/data/com.termux/files/home/clawlite-data/"
    ],
    "python_version_min": "3.11",
    "has_root": false,
    "has_docker": false,
    "has_gui_display": false,
    "cpu_cores_typical": 8,
    "android_version_min": "7.0"
  },
  
  "capabilities_detected": {
    "can_compile_c": false,
    "can_run_docker": false,
    "can_use_gui": false,
    "has_internet": true,
    "has_telegram": true,
    "max_concurrent_agents": 2,
    "safe_timeout_seconds": 10,
    "max_memory_mb": 350,
    "supports_async": true,
    "supports_sqlite": true,
    "supports_onnx": true
  },
  
  "compatible_libraries": {
    "allowed": [
      "requests", "beautifulsoup4", "flask", "fastapi",
      "sqlite3", "rich", "click", "schedule", "pandas",
      "python-telegram-bot", "httpx", "pillow",
      "jinja2", "pydantic", "aiofiles", "python-dateutil",
      "lxml", "urllib3", "certifi", "charset_normalizer",
      "idna", "anyio", "sniffio", "typing_extensions"
    ],
    
    "problematic": [
      "tkinter (no display server disponible)",
      "opencv-python (compilación compleja en ARM64)",
      "matplotlib (solo modo GUI, no disponible)",
      "selenium (requiere ChromeDriver de escritorio)",
      "pyautogui (necesita X11/display)",
      "pyside2 (requiere GUI)",
      "kivy (pesado para móvil)"
    ],
    
    "forbidden": [
      "os.system con shell=True",
      "subprocess.call con shell=True",
      "eval() con input de usuario",
      "exec() con input de usuario",
      "__import__ dinámico con input de usuario",
      "pickle.loads con datos no confiables"
    ]
  },
  
  "performance_tuning": {
    "swarm_max_agents": 2,
    "model_lazy_load": true,
    "cache_aggressive": true,
    "battery_saver_mode": false,
    "thermal_throttling": true,
    "memory_optimization": "high",
    "cpu_affinity": "auto"
  },
  
  "paths": {
    "data_dir": "/sdcard/clawlite-data/",
    "cache_dir": "/sdcard/clawlite-data/cache/",
    "logs_dir": "/sdcard/clawlite-data/logs/",
    "models_dir": "models/keep/",
    "temp_dir": "/sdcard/clawlite-data/tmp/"
  },
  
  "limits": {
    "max_file_size_mb": 50,
    "max_query_length": 1000,
    "max_response_length": 10000,
    "max_concurrent_tasks": 3,
    "max_retries": 3,
    "timeout_short_seconds": 5,
    "timeout_medium_seconds": 15,
    "timeout_long_seconds": 30
  }
}